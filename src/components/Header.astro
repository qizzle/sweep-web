---
import { Image } from "astro:assets";
import sweepLogo from "../assets/sweep.svg";

const { navigationLinks } = Astro.props;
---

<header class="p-3 md:p-4 top-0 flex justify-between fixed w-full z-50">
  <div></div>
  <a class="" href="/sweep-web/">
    <Image
      src={sweepLogo}
      alt="sweep"
      class="w-24 md:w-48 rounded-2xl p-3 md:p-4 backdrop-blur-2xl border border-white/10 hover:opacity-60 transition-opacity"
    />
  </a>
  <button
    onclick="toggleNavigation()"
    class="cursor-pointer px-4 md:px-5 py-2 z-40 flex gap-2 items-center transition opacity-100 backdrop-blur-lg bg-white/10 rounded-2xl hover:opacity-60 border-white/10 border"
    id="navigationButton"
  >
    <svg
      fill="#000000"
      version="1.1"
      id="navigationIcon"
      xmlns="http://www.w3.org/2000/svg"
      xmlns:xlink="http://www.w3.org/1999/xlink"
      width="800px"
      height="800px"
      class="size-4 transition-transform"
      viewBox="0 0 24.75 24.75"
      xml:space="preserve"
    >
      <g>
        <path
          d="M0,3.875c0-1.104,0.896-2,2-2h20.75c1.104,0,2,0.896,2,2s-0.896,2-2,2H2C0.896,5.875,0,4.979,0,3.875z M22.75,10.375H2
		c-1.104,0-2,0.896-2,2c0,1.104,0.896,2,2,2h20.75c1.104,0,2-0.896,2-2C24.75,11.271,23.855,10.375,22.75,10.375z M22.75,18.875H2
		c-1.104,0-2,0.896-2,2s0.896,2,2,2h20.75c1.104,0,2-0.896,2-2S23.855,18.875,22.75,18.875z"
        ></path>
      </g>
    </svg>
    Menü
  </button>
  <div
    id="navigation"
    class="fixed top-0 h-screen w-[84%] sm:w-80 md:w-1/3 bg-white border-l-3 border-black border-dotted -right-[84%] sm:-right-80 md:-right-1/3 overflow-hidden transition-all duration-300"
  >
    <div
      class="mx-8 md:mx-20 mt-24 md:mt-20 text-xl md:text-2xl font-medium h-full flex flex-col z-50"
    >
      {
        // @ts-ignore
        navigationLinks.map((item) => (
          <a class="py-2 relative w-fit group" href={item[1]}>
            {item[0]}
            <div class="absolute bottom-1 w-full h-1 bg-black rounded-full group-hover:opacity-100 opacity-0 transition-opacity" />
          </a>
        ))
      }
    </div>
  </div>
</header>
<div
  class="fixed inset-0 bg-black/45 backdrop-blur z-40 w-full h-screen overflow-hidden opacity-0 transition-opacity pointer-events-none"
  id="navigationDiv"
  onclick="toggleNavigation()"
>
</div>
<script defer>
  function toggleNavigation() {
    // const navigationButton = document.querySelector("#navigationButton");
    const navigation = document.querySelector("#navigation");
    const navigationIcon = document.querySelector("#navigationIcon");
    const navigationDiv = document.querySelector("#navigationDiv");
    if (navigation) {
      navigation.classList.toggle("-right-[84%]");
      navigation.classList.toggle("sm:-right-80");
      navigation.classList.toggle("md:-right-1/3");
      navigation.classList.toggle("right-0");
      navigationIcon.classList.toggle("rotate-90");
      navigationDiv.classList.toggle("opacity-0");
      navigationDiv.classList.toggle("pointer-events-none");
    }
  }
</script>
