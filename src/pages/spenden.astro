---
import "../styles/global.css";
import "@fontsource/geist";
import "@fontsource/geist/600";
import "@fontsource/bitcount-grid-single";
import "@fontsource/geist-mono";

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>SWEEP - Spenden</title>
  </head>
  <body>
    <Header />
    <section class="px-4 md:px-24 mt-32 md:mt-36 mb-12">
      <h1 class="font-bit text-4xl md:text-6xl uppercase text-center mb-6">
        Unterstützen Sie SWEEP
      </h1>
      <p
        class="text-center max-w-4xl mx-auto text-base md:text-lg leading-relaxed"
      >
        Innovative Ideen brauchen Unterstützung. Unser Projekt S.W.E.E.P. zeigt,
        wie moderne Technik und künstliche Intelligenz dazu beitragen können,
        Städte sauberer und nachhaltiger zu machen. Als Schülerprojekt im Rahmen
        von Jugend forscht entwickeln wir unseren autonomen Müllsammelroboter
        kontinuierlich weiter - für neue Tests, bessere Technik und den
        praktischen Einsatz im öffentlichen Raum.
      </p>
    </section>

    <section class="px-4 md:px-24 mb-12">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="border-2 border-dotted p-4 md:p-6">
          <h2 class="font-bit text-3xl md:text-4xl uppercase mb-4">
            So können Sie helfen
          </h2>
          <ul class="list-disc pl-5 space-y-3 text-base md:text-lg">
            <li>
              Spenden, um neue technische Komponenten und Materialien zu
              finanzieren
            </li>
            <li>
              Sachspenden wie Elektronik, Sensorik oder mechanische Bauteile
            </li>
            <li>
              Kooperationen mit Unternehmen, Institutionen oder öffentlichen
              Einrichtungen
            </li>
          </ul>
          <p class="mt-6 text-base md:text-lg leading-relaxed">
            Jede Unterstützung - groß oder klein - hilft uns, aus einer Idee
            eine praktische Lösung für sauberere Städte zu machen.
          </p>
        </div>

        <div
          class="border-2 border-dotted p-4 md:p-6 flex flex-col justify-between gap-6"
        >
          <div>
            <h2 class="font-bit text-3xl md:text-4xl uppercase mb-4">
              QR-Code für Spenden
            </h2>
            <p class="text-base md:text-lg leading-relaxed">
              Scannen Sie diesen QR-Code, um direkt zu unserer
              PayPal-Spendenseite zu gelangen und das SWEEP-Projekt zu
              unterstützen.
            </p>
          </div>
          <div
            class="w-full aspect-square max-w-[320px] mx-auto border-2 border-dotted flex items-center justify-center text-center bg-black/[0.03]"
          >
            <a href="https://www.paypal.com/pools/c/9ngAWStbP9" target="_blank">
              <img
                src="https://genqrcode.com/embedded?style=5&inner_eye_style=0&outer_eye_style=0&logo=51969aea1b46ec92969252ddef20c55e&color=%23000000FF&background_color=%23FFFFFFFF&inner_eye_color=%23000000&outer_eye_color=%23000000&imageformat=svg&language=en&frame_style=0&frame_text=SCAN%20ME&frame_text_icon_color=%23000000&frame_text_icon=null&frame_color=%23000000&frame_background_color=%23FFFFFF&frame_text_color=%23FFFFFF&invert_colors=false&gradient_style=0&gradient_color_start=%23FF0000&gradient_color_end=%237F007F&gradient_start_offset=5&gradient_end_offset=95&stl_type=1&logo_remove_background=true&stl_size=100&stl_qr_height=1.5&stl_base_height=2&stl_include_stands=false&stl_qr_magnet_type=3&stl_qr_magnet_count=0&type=0&text=https%3A%2F%2Fwww.paypal.com%2Fpools%2Fc%2F9ngAWStbP9&width=500&height=500&bordersize=2"
                alt="qr code"
                class="w-full h-full object-contain"
              />
            </a>
          </div>
          <div class="flex flex-col sm:flex-row gap-3">
            <a
              href="https://www.paypal.com/pools/c/9ngAWStbP9"
              target="_blank"
              class="w-full flex items-center justify-center gap-2 text-center px-4 py-2 rounded-full bg-[#003087] text-blue-50 hover:bg-blue-800 transition border border-black/10"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                fill="currentColor"
                class="bi bi-paypal"
                viewBox="0 0 16 16"
              >
                <path
                  d="M14.06 3.713c.12-1.071-.093-1.832-.702-2.526C12.628.356 11.312 0 9.626 0H4.734a.7.7 0 0 0-.691.59L2.005 13.509a.42.42 0 0 0 .415.486h2.756l-.202 1.28a.628.628 0 0 0 .62.726H8.14c.429 0 .793-.31.862-.731l.025-.13.48-3.043.03-.164.001-.007a.35.35 0 0 1 .348-.297h.38c1.266 0 2.425-.256 3.345-.91q.57-.403.993-1.005a4.94 4.94 0 0 0 .88-2.195c.242-1.246.13-2.356-.57-3.154a2.7 2.7 0 0 0-.76-.59l-.094-.061ZM6.543 8.82a.7.7 0 0 1 .321-.079H8.3c2.82 0 5.027-1.144 5.672-4.456l.003-.016q.326.186.548.438c.546.623.679 1.535.45 2.71-.272 1.397-.866 2.307-1.663 2.874-.802.57-1.842.815-3.043.815h-.38a.87.87 0 0 0-.863.734l-.03.164-.48 3.043-.024.13-.001.004a.35.35 0 0 1-.348.296H5.595a.106.106 0 0 1-.105-.123l.208-1.32z"
                ></path>
              </svg>
              Jetzt spenden
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="px-4 md:px-24 mb-16">
      <div class="border-2 border-dotted p-4 md:p-6 text-center">
        <h2 class="font-bit text-3xl md:text-4xl uppercase mb-4">
          Kontakt für Unterstützung und Spenden
        </h2>
        <a
          class="underline text-lg md:text-xl break-words"
          href="mailto:roland.jugendforscht@outlook.com"
          >roland.jugendforscht@outlook.com</a
        >
        <p class="mt-4 text-base md:text-lg">
          Wir freuen uns über jede Nachricht und bedanken uns herzlich für Ihr
          Interesse an unserem Projekt.
        </p>
      </div>
    </section>

    <Footer />
  </body>
</html>
